# === LLM / OpenRouter ===
OPENROUTER_API_KEY=sk-or-v1-...
LLM_MODEL=google/gemma-4-31b-it:free
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# === OpenRouter headers (для free-моделей) ===
HTTP_REFERER=https://github.com/DNikulshin
APP_TITLE=ai-automation-starter

# === Telegram (опционально) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Mock mode (для тестов без расхода токенов) ===
# MOCK_LLM=true